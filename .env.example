# Google Calendar (read-only). Get this from Google Cloud Console.
# See README "Google Calendar" section for setup.
VITE_GOOGLE_CLIENT_ID=

# Cross-device sync (optional). Same secret on client and server.
# Generate a long random string (e.g. openssl rand -hex 32).
# Server (Vercel env): SYNC_SECRET
# Client (Vite, so prefix VITE_): VITE_SYNC_SECRET
VITE_SYNC_SECRET=
